# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000

# Services
POSTGRES_DB=dinosaurios
POSTGRES_USER=dinosaurios
POSTGRES_PASSWORD=dinosaurios
DATABASE_URL=postgres://dinosaurios:dinosaurios@localhost:5432/dinosaurios
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Application URLs
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Product defaults
DEFAULT_LOCALE=es
DEFAULT_TIME_ZONE=America/Lima
DEFAULT_CURRENCY=PEN

# Development email and files
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
PRIVATE_FILE_STORAGE=local
